pipeline {
    agent any

    stages {

        stage('Git Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Suryaj3169/Recon-GYM.git'
            }
        }

        stage('Docker Image Build') {
            steps {
                sh 'docker build -t gym-pro:latest .'
            }
        }

        stage('K8s Deployment') {
            steps {
                sh 'kubectl apply -f Deployment.yml'
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    kubectl get deployments
                    kubectl get pods
                    kubectl get svc
                '''
            }
        }
    }
}