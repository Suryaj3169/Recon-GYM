pipeline{
     agent any
       stages{

         stage('Git Clone'){
             steps{
                 git branch: 'main', url: 'https://github.com/Suryaj3169/Recon-GYM.git'
             }
         }
         stage('Docker Image Build'){
             steps{
                 sh 'docker build -t gym-pro .'
             }
         }
         stage ('Docker container run'){
             steps{
                 sh 'docker run -d -p 80:80 gym-pro'
             }
         }

         stage('k8s Deployment'){
             steps{
                sh 'kubectl apply -f Deployment.yml'
             }
}

}